# ==================== Environment Variables ====================
# ไฟล์นี้ใช้เก็บค่า configuration ที่ไม่ควร commit ขึ้น Git
# Copy ไฟล์นี้เป็น .env และแก้ไขค่าตามความเหมาะสม

# ==================== Database ====================
# MongoDB connection string
# Local: mongodb://localhost:27017/vanbooking
# Production: mongodb+srv://username:password@cluster.mongodb.net/vanbooking
MONGO_URI=mongodb://localhost:27017/vanbooking
MONGODB_URI=mongodb://localhost:27017/vanbooking

# ==================== Authentication ====================
# JWT Secret Key - ต้องเปลี่ยนใน Production!
# สร้างได้จาก: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=change-this-secret-key-in-production-2026

# Token หมดอายุใน
JWT_EXPIRES_IN=7d

# ==================== Server ====================
# Port ที่ server รัน
PORT=5000

# Environment mode
# development = แสดง error stack, log requests
# production = ซ่อน error stack
NODE_ENV=development

# ==================== Firebase (Optional) ====================
# สำหรับ Push Notification - ใส่ path ไปยัง service account file
# GOOGLE_APPLICATION_CREDENTIALS=./firebase-adminsdk.json
